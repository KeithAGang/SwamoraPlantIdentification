# SwamoraPlant Server

## Database
DATABASE_URL=postgres://postgres:password@db:5432/swamora

## App
PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

## Auth — generate with: openssl rand -hex 32
JWT_SECRET=generate_a_strong_random_secret_here

## Google Maps Platform — used by /api/shops to find nearby agro shops.
## Leave blank to use mock results.
# GOOGLE_MAPS_API_KEY=

## Savi chat — Groq LLM. Sign up at https://console.groq.com and create a key.
## Leave blank to run the chat in stub-streaming demo mode.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

## Optional SSL (if not behind a reverse proxy)
# SSL_KEY_PATH=/path/to/privkey.pem
# SSL_CERT_PATH=/path/to/cert.pem
